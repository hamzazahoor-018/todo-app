<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/assets/styles.css" type="text/css">
    <title>Todo</title>
</head>
<body>
    <div class="todo-table">
        <h1>Todo List</h1>
        <p class="todo-subtitle">Capture tasks, add them quickly, and remove them with a click.</p>
        <form action="/todo" method="POST">
            <input type="text" name="item" id="todo-input" placeholder="Enter a todo item">
            <button type="submit">Add</button>
        </form>
        <ul>
            <% for(let i = 0; i < todos.length; i++) { %>
                <li data-id="<%= todos[i]._id %>" data-item="<%= todos[i].item %>"><%= todos[i].item %></li>
            <% } %>
        </ul>
    </div>
    <script src="/assets/todo-list.js"></script>
</body>
</html>